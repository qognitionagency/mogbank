<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <PackageId>MogBank.SemanticKernel</PackageId>
    <Version>1.0.0</Version>
    <Description>Semantic Kernel plugin for MogBank — AI Agent Banking on .NET</Description>
    <Authors>MogBank Team</Authors>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageTags>semantic-kernel;mogbank;ai-agents;agent-banking;usdc</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.SemanticKernel" Version="1.15.0" />
    <PackageReference Include="System.Net.Http.Json" Version="8.0.0" />
  </ItemGroup>

</Project>