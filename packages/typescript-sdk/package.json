{
  "name": "@mogbank/sdk",
  "version": "1.0.0",
  "description": "MogBank TypeScript SDK — Agent Banking Infrastructure Client",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    },
    "./agent": {
      "require": "./dist/agent.js",
      "import": "./dist/agent.mjs",
      "types": "./dist/agent.d.ts"
    },
    "./wallet": {
      "require": "./dist/wallet.js",
      "import": "./dist/wallet.mjs",
      "types": "./dist/wallet.d.ts"
    },
    "./transfer": {
      "require": "./dist/transfer.js",
      "import": "./dist/transfer.mjs",
      "types": "./dist/transfer.d.ts"
    },
    "./marketplace": {
      "require": "./dist/marketplace.js",
      "import": "./dist/marketplace.mjs",
      "types": "./dist/marketplace.d.ts"
    },
    "./faucet": {
      "require": "./dist/faucet.js",
      "import": "./dist/faucet.mjs",
      "types": "./dist/faucet.d.ts"
    },
    "./crypto": {
      "require": "./dist/crypto.js",
      "import": "./dist/crypto.mjs",
      "types": "./dist/crypto.d.ts"
    },
    "./stream": {
      "require": "./dist/stream.js",
      "import": "./dist/stream.mjs",
      "types": "./dist/stream.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/agent.ts src/wallet.ts src/transfer.ts src/marketplace.ts src/faucet.ts src/crypto.ts src/stream.ts --format cjs,esm --dts --clean",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build",
    "test": "jest",
    "lint": "eslint src --ext .ts"
  },
  "keywords": ["mogbank", "ai-agents", "agent-banking", "abos", "x402", "usdc", "base"],
  "license": "MIT",
  "dependencies": {
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  },
  "files": ["dist", "README.md"]
}